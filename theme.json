	"styles": {
		"blocks": {
			"core/quote": {
				"variations": {
					"plain": {
						"typography": {
							"fontFamily": "var(--wp--preset--font-family--font-main)",
							"fontSize": "var(--wp--preset--font-size--heading-2)",
							"lineHeight": "var(--wp--custom--line-height--headings)",
							"fontStyle": "italic"
						},
						"spacing": {
							"margin": {
								"left": "0",
								"right": "0",
								"top": "var(--wp--custom--layout--gap)",
								"bottom": "var(--wp--custom--layout--gap)"
							},
							"padding": {
								"left": "0"
							}
						}
					}
				}
			},
			"core/media-text": {
				"spacing": {
					"blockGap": "var(--wp--custom--layout--gap-large)"
				}
			},
			"core/cover": {
				"spacing": {
					"padding": {
						"top": "var(--wp--custom--layout--gap-large)",
						"bottom": "var(--wp--custom--layout--gap-large)",
						"left": "var(--wp--custom--layout--gap)",
						"right": "var(--wp--custom--layout--gap)"
					}
				}
			},
			"core/buttons": {
				"spacing": {
					"blockGap": "var(--wp--custom--layout--gap-small)"
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--neutral-white)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"elements": {
			"button": {
				"border": {
					"radius": "var(--wp--custom--border-radius--rounded)",
					"width": "0px"
				},
				"color": {
					"background": "var(--wp--preset--color--primary-10)",
					"text": "var(--wp--preset--color--foreground)"
				},
				"spacing": {
					"padding": "1rem 1.25rem"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--font-main)",
					"fontSize": "var(--wp--preset--font-size--16)",
					"lineHeight": "var(--wp--custom--line-height--headings)"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary-100)",
						"text": "var(--wp--preset--color--neutral-white)"
					}
				}
			},
			"caption": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--font-main)",
					"fontSize": "var(--wp--preset--font-size--caption)",
					"lineHeight": "var(--wp--custom--line-height--tiny)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--heading-1)",
					"lineHeight": "var(--wp--custom--line-height--tiny)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--heading-2)",
					"lineHeight": "var(--wp--custom--line-height--tiny)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--heading-3)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--heading-4)"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--heading-5)"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--heading-6)"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--font-main)",
					"lineHeight": "var(--wp--custom--line-height--headings)",
					"fontWeight": "400"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--font-main)"
				}
			},
			"cite": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--font-main)", 
					"fontSize": "var(--wp--preset--font-size--body)"
				}
			}
		},
		"spacing": {
			"blockGap": "var(--wp--custom--layout--gap)",
			"padding": {
				"bottom": "0px",
				"left": "1rem",
				"right": "1rem",
				"top": "0px"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--font-main)",
			"fontSize": "var(--wp--preset--font-size--body)",
			"lineHeight": "var(--wp--custom--line-height--normal)"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	],
	"version": 3
}